    {
      "name": "server_configs",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"server_configs\" (\"id\" TEXT NOT NULL, \"bge_server_id\" TEXT UNIQUE NOT NULL, \"display_name\" TEXT NOT NULL, \"server_url\" TEXT UNIQUE COLLATE NOCASE NOT NULL, \"connection_state\" TEXT NOT NULL, \"cached_identity_json\" TEXT NOT NULL, \"last_identity_fetched_at\" TEXT NOT NULL, \"last_active_at\" TEXT NULL, \"backgrounding_timeout_seconds\" INTEGER NULL, \"metadata\" TEXT NOT NULL DEFAULT '{}', \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "device_preferences",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"device_preferences\" (\"id\" TEXT NOT NULL, \"max_monitored_servers\" INTEGER NOT NULL DEFAULT 5, \"backgrounding_timeout_desktop_seconds\" INTEGER NOT NULL DEFAULT 900, \"backgrounding_timeout_mobile_seconds\" INTEGER NOT NULL DEFAULT 300, \"battery_aware_transitions\" INTEGER NOT NULL DEFAULT 0 CHECK (\"battery_aware_transitions\" IN (0, 1)), \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "notification_summaries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"notification_summaries\" (\"id\" TEXT NOT NULL, \"local_server_id\" TEXT NOT NULL, \"bge_server_id\" TEXT NOT NULL, \"server_display_name\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"body\" TEXT NULL, \"is_read\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_read\" IN (0, 1)), \"requires_full_load\" INTEGER NOT NULL DEFAULT 0 CHECK (\"requires_full_load\" IN (0, 1)), \"received_at\" TEXT NOT NULL, \"created_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
