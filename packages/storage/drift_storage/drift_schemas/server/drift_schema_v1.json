  "fixed_sql": [
    {
      "name": "games",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"games\" (\"id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"subtitle\" TEXT NULL, \"description\" TEXT NULL, \"image\" TEXT NULL, \"thumbnail\" TEXT NULL, \"publish_year\" INTEGER NULL, \"min_players\" INTEGER NULL, \"max_players\" INTEGER NULL, \"playing_time\" INTEGER NULL, \"min_play_time\" INTEGER NULL, \"min_play_time_measure\" TEXT NULL, \"max_play_time\" INTEGER NULL, \"max_play_time_measure\" TEXT NULL, \"min_age\" INTEGER NULL, \"complexity\" REAL NULL, \"content_type\" TEXT NOT NULL DEFAULT 'BaseGame', \"total_play_count\" INTEGER NOT NULL DEFAULT 0, \"average_rating\" REAL NULL, \"bayes_rating\" REAL NULL, \"ratings_count\" INTEGER NULL, \"owned_by_count\" INTEGER NOT NULL DEFAULT 0, \"categories_json\" TEXT NOT NULL DEFAULT '[]', \"mechanics_json\" TEXT NOT NULL DEFAULT '[]', \"designers_json\" TEXT NOT NULL DEFAULT '[]', \"publishers_json\" TEXT NOT NULL DEFAULT '[]', \"tags_json\" TEXT NOT NULL DEFAULT '[]', \"visibility\" TEXT NOT NULL DEFAULT 'Public', \"created_by_id\" TEXT NULL, \"deleted_at\" TEXT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "platform_games",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"platform_games\" (\"id\" TEXT NOT NULL, \"game_id\" TEXT NOT NULL REFERENCES games (id), \"platform_id\" TEXT NOT NULL, \"platform_name\" TEXT NOT NULL, \"min_players\" INTEGER NULL, \"max_players\" INTEGER NULL, \"min_play_time\" INTEGER NULL, \"min_play_time_measure\" TEXT NULL, \"max_play_time\" INTEGER NULL, \"max_play_time_measure\" TEXT NULL, \"image\" TEXT NULL, \"thumbnail\" TEXT NULL, \"supports_solo\" INTEGER NOT NULL DEFAULT 0 CHECK (\"supports_solo\" IN (0, 1)), \"supports_local\" INTEGER NOT NULL DEFAULT 0 CHECK (\"supports_local\" IN (0, 1)), \"supports_online\" INTEGER NOT NULL DEFAULT 0 CHECK (\"supports_online\" IN (0, 1)), \"has_async_play\" INTEGER NOT NULL DEFAULT 0 CHECK (\"has_async_play\" IN (0, 1)), \"has_realtime\" INTEGER NOT NULL DEFAULT 0 CHECK (\"has_realtime\" IN (0, 1)), \"has_tutorial\" INTEGER NOT NULL DEFAULT 0 CHECK (\"has_tutorial\" IN (0, 1)), \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "game_collections",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"game_collections\" (\"id\" TEXT NOT NULL, \"user_id\" TEXT NOT NULL, \"platform_game_id\" TEXT NOT NULL REFERENCES platform_games (id), \"medium\" TEXT NOT NULL, \"release_id\" TEXT NULL, \"quantity\" INTEGER NOT NULL DEFAULT 1, \"rating\" INTEGER NULL, \"play_count\" INTEGER NULL, \"play_again\" INTEGER NULL CHECK (\"play_again\" IN (0, 1)), \"favorite\" INTEGER NULL CHECK (\"favorite\" IN (0, 1)), \"comment\" TEXT NULL, \"last_played\" TEXT NULL, \"last_updated\" TEXT NULL, \"is_dirty\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_dirty\" IN (0, 1)), \"is_local_only\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_local_only\" IN (0, 1)), \"deleted_at\" TEXT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "households",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"households\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"description\" TEXT NULL, \"image\" TEXT NULL, \"deleted_at\" TEXT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
