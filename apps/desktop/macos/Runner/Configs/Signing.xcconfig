// Code signing for the Runner target.
//
// This is an open-source project: anyone can clone, build, and modify it, so
// no specific Apple Developer team or pinned certificate is committed here.
// The generic "Apple Development" identity below is safe to track: with
// automatic signing it resolves to whichever development cert the contributor
// has for their team, so builds work for contributors and forks without
// editing tracked files. A real identity (not ad-hoc "-") is required because
// the Runner entitlements include keychain-access-groups, which can only be
// provisioned with a development certificate.
//
// Distribution/archive builds (Developer ID / Apple Distribution) override this
// from CI, e.g. `xcodebuild CODE_SIGN_IDENTITY="Developer ID Application" ...`.
//
CODE_SIGN_IDENTITY = Apple Development
//
// Provide your team in ONE of these ways:
//   * Xcode: select your team under Signing & Capabilities (writes to your
//     local, untracked project state), or
//   * create a git-ignored Signing.local.xcconfig next to this file:
//         DEVELOPMENT_TEAM = ABCDE12345
//   * CI / official release builds: pass DEVELOPMENT_TEAM to the build
//     (env var or `xcodebuild DEVELOPMENT_TEAM=...`), which overrides this file.
//
// Entitlements live in the Runner/*.entitlements files.
#include? "Signing.local.xcconfig"
